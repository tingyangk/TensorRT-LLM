# Triton model configuration for models using the encode-only path
# served via the TensorRT-LLM LLM API encode() path.
#
# Key differences from the decoder llmapi/ backend:
#   - Dynamic batching ENABLED (encoder forward is a single pass)
#   - Synchronous (coupled) execution — no streaming
#   - No sampling parameters
#   - Output is logits/embeddings

name: "tensorrt_llm"
backend: "python"

####################################################################
# Dynamic batching collects individual requests into
# batches before calling execute(). The largest preferred_batch_size
# should match max_batch_size both in here and model.yaml.
####################################################################
max_batch_size: 64

dynamic_batching {
  preferred_batch_size: [1, 2, 4, 8, 16, 32, 64]
  max_queue_delay_microseconds: 1000
}

instance_group [
  {
    count: 1
    kind : KIND_CPU
  }
]

input [
  {
    name: "text_input"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

output [
  {
    name: "logits"
    data_type: TYPE_FP32
    dims: [ -1 ]
  },
  {
    name: "predictions"
    data_type: TYPE_INT32
    dims: [ -1 ]
  }
]
